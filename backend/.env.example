# 开发环境 — SQLite（无需 Docker）
DATABASE_URL=sqlite+aiosqlite:///./lexiconprep.db

# 生产环境 — PostgreSQL（需要 Docker）
# docker compose up -d
# DATABASE_URL=postgresql+asyncpg://lexicon:lexicon123@localhost:5432/lexiconprep

REDIS_URL=
JWT_SECRET_KEY=<your-secret-key-here>
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
RATE_LIMIT_PER_MINUTE=60
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
DEBUG=false

